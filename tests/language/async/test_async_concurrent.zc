
// Stackless coroutine tests (P1)

async fn slow_double(x: int) -> int {
    return x * 2;
}

async fn slow_add(a: int, b: int) -> int {
    return a + b;
}

async fn three_async(a: int, b: int, c: int) -> int {
    return a + b + c;
}

test "await one-liner" {
    let r = await slow_double(10);
    assert(r == 20, "one-liner await");
}

test "await with args" {
    let r = await slow_add(100, 200);
    assert(r == 300, "await with args");
}

test "sequential awaits" {
    let a = await slow_double(5);
    let b = await slow_add(a, 10);
    assert(b == 20, "sequential awaits");
}

test "three sequential" {
    let r = await three_async(1, 2, 3);
    assert(r == 6, "three sequential");
}
