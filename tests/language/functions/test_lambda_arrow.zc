
fn compute(op: fn(I32, I32) -> I32, a: I32, b: I32) -> I32 {
    return op(a, b);
}

test "test_lambda_arrow" {
    let doubler = x -> x * 2;
    let res1 = doubler(5);
    "doubler(5) = {res1}";
    assert(res1 == 10, "doubler(5) should be 10");

    let add = (x, y) -> x + y;
    let res2 = add(10, 20);
    "add(10, 20) = {res2}";
    assert(res2 == 30, "add(10, 20) should be 30");
    
    let res3 = compute((a, b) -> a * b, 3, 4);
    "compute((a, b) -> a * b, 3, 4) = {res3}";
    assert(res3 == 12, "compute((a, b) -> a * b, 3, 4) should be 12");
}

test "lambda_inference_repro" {
    let dble = x -> x * 2.0;
    let res = dble(9.0);
    assert(res == 18.0, "dble(9.0) should be 18.0");
}
