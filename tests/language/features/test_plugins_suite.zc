// language/features: test_plugins_suite
import plugin "plugins/brainfuck" as bf
import plugin "plugins/forth" as forth
import plugin "plugins/sql" as sql
import plugin "plugins/lisp" as lisp
import plugin "plugins/befunge" as befunge

// --- Unified Plugin Verification Suite ---

test "Lisp Modernized Hoisting" {
    println "Testing Lisp (Hoisted defun)...";
    lisp! {
        (defun square (x) (* x x))
        (defun cube (x) (* x (square x)))
        (print (cube 3))
    }
    println ""; // expected output: 27
}

test "Lisp Basic Operations" {
    println "Testing Lisp Basics...";
    lisp! {
        (print (+ 10 20))
        (print (- 100 50))
    }
    println "";
}

test "SQL Native Plugin" {
    println "Testing SQL (SQLite-style emission)...";
    sql! {
        CREATE TABLE users (id INTEGER, name TEXT);
        INSERT INTO users VALUES (1, 'Zen Master');
    }
    println "DONE";
}

test "Forth Native Plugin" {
    println "Testing Forth (Postfix stack)...";
    forth! {
        10 20 + .
        5 6 * .
    }
    println "";
}

test "Brainfuck Native Plugin" {
    println "Testing Brainfuck (Inline emission)...";
    bf! {
        ++++++++++[>+++++++>++++++++++>+++>+<<<<-]>++.>+.+++++++..+++.>++.<<+++++++++++++++.>.+++.------.--------.>+.>.
    }
    println "";
}

test "Befunge Native Plugin" {
    println "Testing Befunge (Grid navigation)...";
    befunge! {
        >25*"!A",,,@
    }
    println "";
}

fn main() {
    println "### Running Unified Plugin Test Suite ###";
    _z_run_tests();
    println "### All Plugin Tests Completed ###";
}
