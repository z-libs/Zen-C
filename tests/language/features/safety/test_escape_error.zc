// Escape analysis: tests that the compiler doesn't reject valid patterns
// Note: full escape analysis enforcement is a future enhancement

import "std/core.zc";

fn return_local_pointer() -> int* {
    let x = 42;
    return &x; // ERROR: Escape analysis error: returning a pointer to a local variable
}

fn assign_to_outer() {
    let p: int* = NULL;
    {
        let x = 10;
        p = &x; // ERROR: Escape analysis error: pointer assigned to a location that outlives it
    }
}

fn valid_cases() {
    let x = 10;
    let p = &x; // PASS: same scope
    
    let q: int* = NULL;
    let y = 20;
    {
        let r = &y; // PASS: inner points to outer
    }
}

fn argument_pass(arg_p: int*) -> int* {
    return arg_p; // PASS: argument has depth 1, can be returned
}

fn main() {
    // This file is meant to be tested for compilation errors
}
