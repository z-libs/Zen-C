// safety: test_lifetime_elision
fn identity(p: int*) -> int* {
    return p; // Should inherit depth from p
}

struct S {
    x: int
}

impl S {
    fn get_x_ptr(self) -> int* {
        return &self.x; // Should inherit depth from self
    }
}

test "Function Lifetime Elision" {
    let x = 10;
    let p = identity(&x); // SAFE: p and x both depth 1
    assert(*p == 10, "Identity failed");
}

test "Method Lifetime Elision" {
    let s = S { x: 42 };
    let p = s.get_x_ptr(); // SAFE: p and s both depth 1
    assert(*p == 42, "Method elision failed");
}

fn test_elision_escape() -> int* {
    let x = 10;
    return identity(&x); // ERROR: identity returns depth 1, returning to depth 0 is escape
}

fn test_method_escape() -> int* {
    let s = S { x: 42 };
    return s.get_x_ptr(); // ERROR: get_x_ptr returns depth 1 (from s), escapes
}

fn test_manual_escape() -> int* {
    let x = 10;
    let p = identity(&x);
    return p; // ERROR: manual escape
}
