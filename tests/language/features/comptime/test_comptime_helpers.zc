comptime {
    compile_warn("This is a compile-time warning test");
    yield("def TEST_YIELD_VAL = 42;");

    let DEBUG = 1;
    if (DEBUG == 0) {
        compile_error("Debug mode required!");
    }
}

test "comptime_yield" {
    assert(TEST_YIELD_VAL == 42, "yield-generated constant failed");
    println "yield() works correctly";
}

test "comptime_conditional" {
    println "Conditional logic in comptime works";
}
