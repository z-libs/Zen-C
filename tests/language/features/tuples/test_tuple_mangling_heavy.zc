// language/features/tuples: tuples: test_tuple_mangling_heavy
// Tuple mangling with complex type names (pointers, nested types)

struct Custom { val: int; }

fn ptr_tuple() -> (int*, string*) {
    let x = 42;
    let y = "hello";
    return (&x, &y);
}

test "pointer tuple" {
    let t = ptr_tuple();
    assert(*t.0 == 42, "ptr tuple 0");
    assert(strcmp(*t.1, "hello") == 0, "ptr tuple 1");
}


