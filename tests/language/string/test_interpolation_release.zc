// string: test_interpolation_release
import "std/string.zc"

fn getter(c: int*) -> String {
    *c = *c + 1
    return String::new("Effect")
}

fn main() {
    let s = String::new("Test")
    
    // Test basic interpolation
    println "Value: {s}"
    
    // Test multiple interpolation in one statement (verifies unique names)
    println "{s} - {s}"
    
    // Test interpolation with method call
    println "C-str: {s.c_str()}"

    // Test with side effects (verifies single evaluation)
    let count = 0
    println "Getter: {getter(&count)}"
    if (count != 1) {
        printf("Error: getter called %d times, expected 1\n", count)
    }
    assert(count == 1, "getter should be called exactly once");
}
