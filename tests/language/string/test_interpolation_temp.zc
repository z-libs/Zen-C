import "std/string.zc"

fn create_temp(val: char*) -> String {
    return String::new(val)
}

fn count_and_create(c: int*, val: char*) -> String {
    *c = *c + 1
    return String::new(val)
}

fn main() {
    // 1. Interpolate temporary String from function call
    println "Temp: {create_temp(\"Temporary String Object\")}"
    
    // 2. Interpolate temporary String with side effects
    let count = 0
    println "Side Effect: {count_and_create(&count, \"Dynamic\")}"
    if (count != 1) {
        printf("Error: count_and_create called %d times, expected 1\n", count)
        exit(1)
    }

    // 3. Complex nesting
    println "Nested: {create_temp(\"Outer\")} and {create_temp(\"Inner\")}"

    // 4. Test with explicit format on temporary (if applicable, though String doesn't have many)
    println "Pointer of Temp: {create_temp(\"Addr\"): %p}"
}
