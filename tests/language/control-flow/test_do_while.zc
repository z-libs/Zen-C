// language/control-flow: control-flow: test_do_while
test "basic do/while" {
    let i = 0;
    do {
        i = i + 1;
    } while i < 5;
    assert(i == 5, "do/while loop executed 5 times");
}

test "run at least once" {
    let ran = false;
    do {
        ran = true;
    } while false;
    assert(ran, "do/while ran at least once even if condition is false");
}

test "break in do/while" {
    let i = 0;
    do {
        i = i + 1;
        if i == 3 {
            break;
        }
    } while i < 10;
    assert(i == 3, "do/while successfully broke at 3");
}

test "continue in do/while" {
    let i = 0;
    let skips = 0;
    do {
        i = i + 1;
        if i % 2 == 0 {
            skips = skips + 1;
            continue;
        }
    } while i < 5;
    assert(skips == 2, "do/while continue skipped even numbers");
    assert(i == 5, "do/while reached the end of condition evaluation");
}
