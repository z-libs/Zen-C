// language/control-flow: control-flow: test_enumerated_for
test "enumerated range loop" {
    let sum_idx = 0;
    let sum_val = 0;
    println "Running test: enumerated range loop";
    for i, val in 0..5 {
        sum_idx = sum_idx + i;
        sum_val = sum_val + val;
    }
    // idx: 0+1+2+3+4 = 10, val: 0+1+2+3+4 = 10
    assert(sum_idx == 10, "Enumerated range: idx sum failed");
    assert(sum_val == 10, "Enumerated range: val sum failed");
}

test "enumerated range loop with step" {
    let sum_idx = 0;
    let sum_val = 0;
    for i, val in 0..10 step 2 {
        sum_idx = sum_idx + i;
        sum_val = sum_val + val;
    }
    // val: 0, 2, 4, 6, 8 -> sum = 20
    // idx: 0, 1, 2, 3, 4 -> sum = 10
    assert(sum_idx == 10, "Enumerated range step: idx sum failed");
    assert(sum_val == 20, "Enumerated range step: val sum failed");
}

test "enumerated array loop" {
    let arr: int[4] = [10, 20, 30, 40];
    let sum_idx = 0;
    let sum_val = 0;
    for i, val in arr {
        sum_idx = sum_idx + i;
        sum_val = sum_val + val;
    }
    // idx: 0+1+2+3 = 6
    // val: 10+20+30+40 = 100
    assert(sum_idx == 6, "Enumerated array: idx sum failed");
    assert(sum_val == 100, "Enumerated array: val sum failed");
}

test "non-enumerated still works" {
    let sum = 0;
    for val in 0..5 {
        sum = sum + val;
    }
    assert(sum == 10, "Non-enumerated range still works");
}

test "non-enumerated array still works" {
    let arr: int[3] = [100, 200, 300];
    let sum = 0;
    for val in arr {
        sum = sum + val;
    }
    assert(sum == 600, "Non-enumerated array still works");
}
