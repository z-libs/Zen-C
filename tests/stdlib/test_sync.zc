// stdlib: test_sync
import "std/sync.zc"
import "std/thread.zc"
import "std/io.zc"

struct SharedData {
    val: int;
    ready: bool;
    mutex: Mutex;
    cond: CondVar;
}

test "test_condvar" {
    println "Testing CondVar...";
    
    let data = (SharedData*)malloc(sizeof(SharedData));
    data.mutex.handle = NULL;
    data.cond.handle = NULL;
    
    data.val = 0;
    data.ready = false;
    data.mutex = Mutex::new();
    data.cond = CondVar::new();
    
    let t = Thread::spawn(fn() {
        sleep_ms(100);
        data.mutex.lock();
        data.val = 42;
        data.ready = true;
        data.cond.signal();
        data.mutex.unlock();
    });
    
    data.mutex.lock();
    while (!data.ready) {
        data.cond.wait(&data.mutex);
    }
    let res = data.val;
    data.mutex.unlock();
    
    assert(res == 42, "CondVar wait failed");
    
    t.unwrap().join();
    
    data.cond.free();
    data.mutex.free();
    free(data);
    println "CondVar Test Passed!";
}

struct RwData {
    val: int;
    lock: RwLock;
}

test "test_rwlock" {
    println "Testing RwLock...";
    
    let data = (RwData*)malloc(sizeof(RwData));
    data.lock.handle = NULL;
    
    data.val = 100;
    data.lock = RwLock::new();
    
    // Multiple readers
    let t1 = Thread::spawn(fn() {
        data.lock.rdlock();
        sleep_ms(50);
        assert(data.val == 100, "RwLock reader 1 failed");
        data.lock.unlock();
    });
    
    let t2 = Thread::spawn(fn() {
        data.lock.rdlock();
        sleep_ms(50);
        assert(data.val == 100, "RwLock reader 2 failed");
        data.lock.unlock();
    });
    
    t1.unwrap().join();
    t2.unwrap().join();
    
    // Writer
    let t3 = Thread::spawn(fn() {
        data.lock.wrlock();
        data.val = 200;
        data.lock.unlock();
    });
    
    t3.unwrap().join();
    
    data.lock.rdlock();
    assert(data.val == 200, "RwLock writer failed");
    data.lock.unlock();
    
    data.lock.free();
    free(data);
    println "RwLock Test Passed!";
}
