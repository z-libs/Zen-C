// stdlib/networking: test_dns
import "std/net/dns.zc"
import "std/string.zc"



test "DNS Resolve" {
    let res = Dns::resolve("localhost");
    assert(!res.is_err(), "Resolve localhost");
    
    let ip = res.unwrap();
    assert(!ip.is_empty(), "Resolved IP not empty");
    assert(ip.eq_str("127.0.0.1"), "Resolved to 127.0.0.1");
    ip.free();
}
