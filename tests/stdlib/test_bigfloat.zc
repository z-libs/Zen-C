// test_bigfloat
import "std/bigfloat.zc"
import "std/io.zc"

test "bigfloat" {
    // 1.23 + 4.567 = 5.797
    let a = BigFloat::from_int(123);
    a.scale = 2;
    
    let b = BigFloat::from_int(4567);
    b.scale = 3;
    
    let sum = a.add(b);
    
    let s = sum.to_string();
    println "1.23 + 4.567 = {s}";
    free(s);
    
    // 0.001 + 0.01 = 0.011
    let c = BigFloat::from_int(1);
    c.scale = 3;
    
    let d = BigFloat::from_int(1);
    d.scale = 2;
    
    let sum2 = c.add(d);
    let s2 = sum2.to_string();
    println "0.001 + 0.01 = {s2}";
    free(s2);

    // 100 + 0.001 = 100.001
    let e = BigFloat::from_int(100);
    e.scale = 0;
    
    let f = BigFloat::from_int(1);
    f.scale = 3;
    
    let sum3 = e.add(f);
    let s3 = sum3.to_string();
    println "100 + 0.001 = {s3}";
    free(s3);
}
