// EXPECT: FAIL
// compiler/analysis: test_move_nested_wrapper_double_consume  --  should fail compilation
import "std/string.zc"

struct Inner {
    data: String;
}

struct Outer {
    inner: Inner;
}

fn consume(o: Outer) {}

fn main() {
    let s = String::new("hello");
    let inner = Inner { data: s };
    let outer = Outer { inner: inner };
    consume(outer);
    consume(outer);
}
