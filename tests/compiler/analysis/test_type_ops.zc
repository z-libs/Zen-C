// compiler/analysis: type analysis: test_type_ops
// Binary and unary operator type validation

// --- Binary arithmetic ---
test "arithmetic i32" {
    let a: i32 = 10;
    let b: i32 = 3;
    let _sum = a + b;
    let _diff = a - b;
    let _prod = a * b;
    let _quot = a / b;
    let _rem = a % b;
    assert(true, "i32 arithmetic ok");
}

// --- Binary comparison ---
test "comparison" {
    let a = 10;
    let b = 20;
    let _eq = a == b;
    let _ne = a != b;
    let _lt = a < b;
    let _gt = a > b;
    let _le = a <= b;
    let _ge = a >= b;
    assert(_eq == false && _lt == true, "comparison ok");
}

// --- Logical operators ---
test "logical ops" {
    let t = true;
    let f = false;
    let _and = t && f;
    let _or = t || f;
    let _not = !t;
    assert(_and == false && _or == true && _not == false, "logical ops ok");
}

// --- Bitwise operators ---
test "bitwise ops" {
    let a: i32 = 0xFF;
    let b: i32 = 0x0F;
    let _and = a & b;
    let _or = a | b;
    let _xor = a ^ b;
    let _not = ~a;
    let _shl = a << 2;
    let _shr = a >> 2;
    assert(true, "bitwise ops ok");
}

// --- Unary minus ---
test "unary minus" {
    let x = 42;
    let _neg = -x;
    assert(_neg == -42, "unary minus ok");
}

// --- Pointer dereference and address-of ---
test "pointer ops" {
    let x: i32 = 42;
    let p = &x;
    let _val = *p;
    assert(_val == 42, "pointer deref ok");
}

// --- Reassignment ---
test "reassign" {
    let x = 10;
    x = x + 1;
    assert(x == 11, "reassign ok");
}

// --- Chained reassignment ---
test "chained reassign" {
    let x = 10;
    x = x + 5;
    x = x * 2;
    assert(x == 30, "chained reassign ok");
}
