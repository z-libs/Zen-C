// compiler/analysis: type analysis: test_type_const_fold
// Constant folding and compile-time evaluation tests

// --- Def constant ---
def FIVE = 5;

test "def basic" {
    assert(FIVE == 5, "def basic ok");
}

// --- Def from expression ---
def TEN = FIVE + FIVE;

test "def expr" {
    assert(TEN == 10, "def expr ok");
}

// --- Array literal ---
test "array literal" {
    let arr = [1, 2, 3, 4];
    assert(arr[0] == 1 && arr[3] == 4, "array literal ok");
}

// --- Match to select value ---
fn pick(x: i32) -> string {
    match x {
        10 => { return "ten"; }
        _ => { return "other"; }
    }
}

test "match with def" {
    assert(pick(10) == "ten", "match with def ok");
    assert(pick(99) == "other", "match with def default ok");
}
