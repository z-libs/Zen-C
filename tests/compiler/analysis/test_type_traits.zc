// compiler/analysis: type analysis: test_type_traits
// Trait system tests

trait Drawable {
    fn draw(self);
}

trait Area {
    fn area(self) -> f64;
}

struct Circle { radius: f64; }

impl Drawable for Circle {
    fn draw(self) {
        println "circle(r={self.radius})";
    }
}

impl Area for Circle {
    fn area(self) -> f64 {
        return 3.14159 * self.radius * self.radius;
    }
}

struct Square { side: f64; }

impl Area for Square {
    fn area(self) -> f64 {
        return self.side * self.side;
    }
}

// --- Trait method call ---
test "trait method" {
    let c = Circle { radius: 2.0 };
    c.draw();
    assert(true, "trait method ok");
}

// --- Trait method return value ---
test "trait method return" {
    let c = Circle { radius: 1.0 };
    let a = c.area();
    assert(a > 3.14 && a < 3.15, "trait method return ok");
}

// --- Multiple traits on same type ---
test "multiple traits" {
    let c = Circle { radius: 2.0 };
    c.draw();
    let a = c.area();
    assert(a > 12.56 && a < 12.57, "multiple traits ok");
}

// --- Trait on multiple types ---
test "trait multiple types" {
    let c = Circle { radius: 3.0 };
    let s = Square { side: 4.0 };
    let ca = c.area();
    let sa = s.area();
    assert(ca > 28.27 && ca < 28.28, "circle area");
    assert(sa == 16.0, "square area");
}
