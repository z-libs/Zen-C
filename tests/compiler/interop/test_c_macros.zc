// compiler/interop: interop: test_c_macros
#define MAX(a, b) ((a) > (b) ? (a) : (b))
#define DEBUG_MODE 1

test "test_c_macros" {
    let x = MAX(10, 20);
    
    assert(x == 20, "MAX(10, 20) should be 20");

    #ifdef DEBUG_MODE
        println "Debug mode active";
    #endif

    #ifndef INVALID_MACRO
        println "Conditionals working";
    #endif
}
