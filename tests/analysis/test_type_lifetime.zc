
// Lifetime / escape analysis tests

// --- Borrow field via method ---
struct Widget { val: i32; }

impl Widget {
    fn get_ref(self) -> i32* {
        return &self.val;
    }
}

test "borrow field" {
    let w = Widget { val: 42 };
    let p = w.get_ref();
    assert(*p == 42, "borrow field ok");
}

