
// Return type checking and control flow analysis

// --- Void function ---
fn do_nothing() {
    // no return needed
}

test "void fn" {
    do_nothing();
    assert(true, "void fn ok");
}

// --- Simple return ---
fn answer() -> i32 {
    return 42;
}

test "simple return" {
    let a = answer();
    assert(a == 42, "simple return ok");
}

// --- If/else both return ---
fn max(a: i32, b: i32) -> i32 {
    if a > b {
        return a;
    } else {
        return b;
    }
}

test "if else return" {
    let m = max(10, 20);
    assert(m == 20, "if else return ok");
}

// --- Match with default ---
fn classify(x: i32) -> string {
    match x {
        0 => return "zero";
        1 => return "one";
        _ => return "other";
    }
}

test "match return" {
    let c = classify(1);
    assert(c == "one", "match return ok");
}

// --- Expression return ---
fn dbl(x: i32) -> i32 {
    return x * 2;
}

test "return expr" {
    assert(dbl(5) == 10, "return expr ok");
}

// --- Early return ---
fn maybe(x: i32) -> i32 {
    if x < 0 {
        return 0;
    }
    return x;
}

test "early return" {
    assert(maybe(-5) == 0, "early return 1");
    assert(maybe(10) == 10, "early return 2");
}
