// benchmark: test_sort_large
import "../../std/core.zc"
import "../../std/sort.zc"
import "../../std/time.zc"
import "../../std/random.zc"

fn main() {
    let size = 10000;
    let iterations = 100;
    let arr: int[10000];
    
    let start = Time::now();
    
    for (let i = 0; i < iterations; i = i + 1) {
        // Fill with "random" values
        for (let j = 0; j < size; j = j + 1) {
            arr[j] = (size - j); // Worst case for some quicksorts, but let's use it
        }
        
        sort_int(&arr[0], (usize)size);
    }
    
    let end = Time::now();
    let duration = end - start;
    
    printf("Benchmark: Sort Large\n");
    printf("Iterations: %d\n", iterations);
    printf("Duration: %llu ms\n", duration);
    printf("RESULT: %llu\n", duration);
    
    return 0;
}
