// benchmark: test_sha256
import "../../std/core.zc"
import "../../std/crypto/sha256.zc"
import "../../std/time.zc"

fn main() {
    let data = "Zen-C is a high-performance, systems programming language with a focus on safety and simplicity. It features a robust type system, automatic memory management via reference counting, and seamless C interoperability.";
    let start = Time::now();
    let iterations = 10000;
    
    for (let i = 0; i < iterations; i = i + 1) {
        let _hash = Sha256::hash(data);
        // String is auto-dropped
    }
    
    let end = Time::now();
    let duration = end - start;
    
    printf("Benchmark: SHA256\n");
    printf("Iterations: %d\n", iterations);
    printf("Duration: %llu ms\n", duration);
    printf("RESULT: %llu\n", duration);
    
    return 0;
}
