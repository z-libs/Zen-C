
import "std/sync.zc"
import "std/thread.zc"
import "std/io.zc"

let global_once: Once;
let global_counter: int;

fn init_func() {
    global_counter = global_counter + 1;
}

test "test_mutex_trylock" {
    let m = Mutex::new();
    assert(m.try_lock(), "Should lock initially");
    assert(!m.try_lock(), "Should not lock twice");
    m.unlock();
    assert(m.try_lock(), "Should lock after unlock");
    m.unlock();
}

fn once_worker() {
    global_once.call(fn() { init_func(); });
}

test "test_once" {
    global_once = Once::new();
    global_counter = 0;
    
    let t1 = Thread::spawn(fn() { once_worker(); }).unwrap();
    let t2 = Thread::spawn(fn() { once_worker(); }).unwrap();
    
    t1.join();
    t2.join();
    
    assert(global_counter == 1, "Once should only call init_func once");
}

test "test_semaphore" {
    let sem = Semaphore::new(1);
    assert(sem.value() == 1, "Initial value should be 1");
    
    sem.wait();
    assert(sem.value() == 0, "Value should be 0 after wait");
    assert(!sem.try_wait(), "Try wait should fail when 0");
    
    sem.post();
    assert(sem.value() == 1, "Value should be 1 after post");
    assert(sem.try_wait(), "Try wait should succeed when 1");
    
    sem.post();
    sem.post();
    assert(sem.value() == 2, "Value should be 2 after posts");
}

test "test_rwlock_try" {
    let lock = RwLock::new();
    
    assert(lock.try_rdlock(), "Should rdlock initially");
    assert(lock.try_rdlock(), "Should allow multiple rdlocks");
    assert(!lock.try_wrlock(), "Should not allow wrlock during rdlock");
    
    lock.unlock();
    lock.unlock();
    
    assert(lock.try_wrlock(), "Should wrlock initially");
    assert(!lock.try_rdlock(), "Should not allow rdlock during wrlock");
    assert(!lock.try_wrlock(), "Should not allow multiple wrlocks");
    
    lock.unlock();
}

struct BarrierTestData {
    barrier: Barrier;
    m: Mutex;
    counter: int*;
}

test "test_barrier" {
    println "Testing Barrier...";
    
    let data = (BarrierTestData*)malloc(sizeof(BarrierTestData));
    data.barrier = Barrier::new(3);
    data.m = Mutex::new();
    data.counter = (int*)malloc(sizeof(int));
    *(data.counter) = 0;

    let t1 = Thread::spawn(fn() {
        data.m.lock();
        *(data.counter) = *(data.counter) + 1;
        data.m.unlock();
        data.barrier.wait();
    }).unwrap();

    let t2 = Thread::spawn(fn() {
        data.m.lock();
        *(data.counter) = *(data.counter) + 1;
        data.m.unlock();
        data.barrier.wait();
    }).unwrap();

    sleep_ms(100);
    data.m.lock();
    let c = *(data.counter);
    data.m.unlock();
    assert(c == 2, "Both threads should have reached the barrier");

    data.barrier.wait(); // Third "thread" to hit the barrier

    t1.join();
    t2.join();
    
    data.barrier.free();
    data.m.free();
    free(data.counter);
    free(data);
    println "Barrier Test Passed!";
}
