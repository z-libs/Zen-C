import "std/vec.zc"
import "std/io.zc"

// Note: assertions use assert(cond, "msg") directly
// to avoid the string literal requirement.

@derive(Eq, Clone)
struct Point {
    x: int;
    y: int;
}

test "Vec Basics (Construction, Push, Pop, Access)" {
    print "Testing Vec basics...\n";
    let v = Vec<int>::new();
    assert(v.len == 0, "Initial len");
    assert(v.cap == 0, "Initial cap");

    v.push(10);
    v.push(20);
    v.push(30);

    assert(v.len == 3, "Len after push");
    assert(v.get(0) == 10, "get(0)");
    assert(v.get(1) == 20, "get(1)");
    assert(v.get(2) == 30, "get(2)");
    assert(v.last() == 30, "last()");
    assert(v.first() == 10, "first()");

    assert(v.pop() == 30, "pop()");
    assert(v.len == 2, "Len after pop");

    v.set(0, 99);
    assert(v.get(0) == 99, "set()");
    
    // Explicit clean up check (safe idempotent free)
    v.free();
    assert(v.len == 0, "Len after free");
}

test "Vec Capacity and Allocation" {
    print "Testing Vec capacity...\n";
    // with_capacity
    let v1 = Vec<int>::with_capacity(10);
    assert(v1.len == 0, "with_capacity len");
    assert(v1.cap == 10, "with_capacity cap");
    v1.push(1);
    assert(v1.cap == 10, "Cap should not change yet");

    // Implicit grow
    let v2 = Vec<int>::new();
    // Force grow logic: 0 -> 8 -> 16...
    let i = 0;
    while i < 9 {
        v2.push(i);
        i = i + 1;
    }
    assert(v2.cap >= 9, "Capacity grew to hold 9 items");
    // Expected strategy: 0 -> 8 -> 16
    assert(v2.cap == 16, "Growth strategy check (8->16)");
}

test "Vec Modification (Insert, Append, Remove, Clear)" {
    print "Testing Vec modification...\n";
    let v = Vec<int>::new();
    v.push(1);
    v.push(3);
    
    v.insert(1, 2); // [1, 2, 3]
    assert(v.get(1) == 2, "insert middle");
    assert(v.len == 3, "insert len");

    let v2 = Vec<int>::new();
    v2.push(4);
    v2.push(5);
    v.append(v2);
    assert(v.len == 5, "append len");
    for i in 0..5 {
        assert(v.get(i) == i + 1, "append value");
    }

    let val = v.remove(0); // [2, 3, 4, 5]
    assert(val == 1, "remove return");
    assert(v.get(0) == 2, "remove shift");
    assert(v.len == 4, "remove len");

    v.clear();
    assert(v.len == 0, "clear len");
    assert(v.is_empty(), "is_empty");
}

test "Vec Extensions (pop_opt)" {
    print "Testing Vec extensions...\n";
    let v = Vec<int>::new();
    v.push(42);
    
    let opt = v.pop_opt();
    assert(!opt.is_none(), "pop_opt some");
    assert(opt.unwrap() == 42, "pop_opt val");
    
    let empty = v.pop_opt();
    assert(empty.is_none(), "pop_opt none");
}

test "Vec Iteration (Reference and Value)" {
    print "Testing Vec iteration...\n";
    let v = Vec<Point>::new();
    v.push(Point { x: 10, y: 10 });
    v.push(Point { x: 20, y: 20 });

    // 1. Value Iteration
    let sum_val = 0;
    for p in v {
        sum_val = sum_val + p.x;
    }
    assert(sum_val == 30, "Value iteration sum");

    // 2. Reference Iteration (Sugar &v) - In-place modification
    for p in &v {
        (*p).x = (*p).x + 1;
    }
    assert(v.get(0).x == 11, "Ref iter mod 0");
    assert(v.get(1).x == 21, "Ref iter mod 1");

    // 3. Explicit iter_ref()
    for p in v.iter_ref() {
        (*p).y = (*p).y + 2;
    }
    assert(v.get(0).y == 12, "Explicit ref iter mod 0");
    assert(v.get(1).y == 22, "Explicit ref iter mod 1");
}

test "Vec Clone and Drop" {
    print "Testing Vec clone and drop...\n";
    let v = Vec<int>::new();
    v.push(100);
    v.push(200);

    let v2 = v.clone();
    assert(v2.len == 2, "Clone len");
    assert(v2.get(0) == 100, "Clone val 0");
    
    v.set(0, 999);
    assert(v.get(0) == 999, "Original mod");
    assert(v2.get(0) == 100, "Clone independent");

    // Drop is implicit at end of scope.
    // We trust valgrind/previous verification for actual memory free.
    // This test ensures no double-free crashes or logic errors.
}

test "Vec Utils (Reverse, Contains)" {
    print "Testing Vec utils...\n";
    let v = Vec<int>::new();
    v.push(1);
    v.push(2);
    v.push(3);

    v.reverse(); // [3, 2, 1]
    assert(v.get(0) == 3, "Reverse 0");
    assert(v.get(2) == 1, "Reverse 2");

    assert(v.contains(2), "Contains true");
    assert(!v.contains(99), "Contains false");
}
